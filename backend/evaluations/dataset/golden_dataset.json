{
  "version": "1.0.0",
  "description": "Golden dataset de Lore Master — cobertura completa: RAG, CRUD de entidades (5 tipos x 10 casos), todas las combinaciones de categoria valida e invalida, guardrails, generacion de imagen y flujos de ciclo de vida.",
  "created_at": "2026-04-29",
  "collection": {
    "name": "Mundo de Valdorath",
    "description": "Coleccion de referencia para evaluacion automatica del pipeline RAG",
    "seed_document": "evaluations/dataset/golden_seed.txt",
    "seed_document_note": "El archivo golden_seed.txt debe ingestarse antes de ejecutar los casos RAG-* y los casos que generan contenido. Contiene el worldbuilding completo del mundo de Valdorath."
  },
  "category_map": {
    "character": ["backstory", "extended_description", "scene", "chapter"],
    "creature":  ["backstory", "extended_description", "scene"],
    "faction":   ["backstory", "extended_description", "scene"],
    "location":  ["extended_description", "scene"],
    "item":      ["backstory", "extended_description"]
  },
  "cases": [
    {
      "id": "RAG-001",
      "category": "rag_query",
      "description": "Consulta sobre el fundador del reino retorna respuesta con fuentes",
      "input": {
        "query": "Quien fundo el Reino de Valdorath y que construyo durante su reinado?"
      },
      "expected": {
        "http_status": 200,
        "has_answer": true,
        "sources_count_gte": 1,
        "answer_min_length": 80,
        "answer_contains_any": ["Arion", "Valdorath", "Solmara"]
      }
    },
    {
      "id": "RAG-002",
      "category": "rag_query",
      "description": "Consulta corta (menos de 5 chars) retorna 422 por validacion de longitud",
      "input": {
        "query": "ok"
      },
      "expected": {
        "http_status": 422
      }
    },
    {
      "id": "RAG-003",
      "category": "rag_query",
      "description": "Consulta sobre la geografia retorna respuesta con contexto",
      "input": {
        "query": "Describe la geografia de Valdorath: rios, bosques y ciudades principales"
      },
      "expected": {
        "http_status": 200,
        "has_answer": true,
        "sources_count_gte": 1,
        "answer_min_length": 80
      }
    },
    {
      "id": "RAG-004",
      "category": "rag_query",
      "description": "Consulta sobre el sistema magico retorna respuesta con tipos de magia",
      "input": {
        "query": "Que tipos de magia existen en Aetheron y cuales son sus efectos secundarios?"
      },
      "expected": {
        "http_status": 200,
        "has_answer": true,
        "sources_count_gte": 1,
        "answer_min_length": 80,
        "answer_contains_any": ["Sangrado del Alma", "elemental", "arcana", "divina", "magia"]
      }
    },
    {
      "id": "RAG-005",
      "category": "rag_query",
      "description": "Consulta sobre las facciones retorna informacion de organizaciones",
      "input": {
        "query": "Cuales son las principales facciones politicas y religiosas del reino?"
      },
      "expected": {
        "http_status": 200,
        "has_answer": true,
        "sources_count_gte": 1,
        "answer_min_length": 80
      }
    },
    {
      "id": "RAG-006",
      "category": "rag_query",
      "description": "Consulta sobre la plaga retorna informacion del conflicto actual",
