        "query": "Que esta pasando con la plaga misteriosa del Bosque Eterno?"
      },
      "expected": {
        "http_status": 200,
        "has_answer": true,
        "sources_count_gte": 1,
        "answer_min_length": 60
      }
    },
    {
      "id": "RAG-007",
      "category": "rag_query",
      "description": "Consulta con extra_context proporcionado se procesa correctamente",
      "input": {
        "query": "Que relacion tiene este personaje con la fundacion del reino?",
        "extra_context": "El personaje en cuestion es Arion el Plateado, mago fundador."
      },
      "expected": {
        "http_status": 200,
        "has_answer": true,
        "sources_count_gte": 0,
        "answer_min_length": 40
      }
    },
    {
      "id": "RAG-008",
