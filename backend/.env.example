PROJECT_NAME="Lore Master API"
# local | production
ENVIRONMENT="local"
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# LLM (Ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:latest
MAX_TOKENS=2000
TEMPERATURE=0.7

# Embedding
EMBEDDING_MODEL="paraphrase-multilingual-MiniLM-L12-v2"
EMBEDDING_DIMS=384

# RAG
CHUNK_SIZE=512
CHUNK_OVERLAP=50
TOP_K=4
RAG_SCORE_THRESHOLD=0.5

# Vector DB
QDRANT_URL=http://localhost:6333

# Cache
REDIS_URL=redis://localhost:6379/0
CACHE_TTL=3600

# Storage (LocalStack dev)
STORAGE_BACKEND=localstack
S3_ENDPOINT_URL=http://localstack:4566
S3_BUCKET=loremaster-images
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

# Image generation
IMAGE_PROMPT_MAX_TOKENS=150
IMAGE_PROMPT_TARGET_TOKENS=75
IMAGE_PROMPT_TOKEN_LIMIT=512
IMAGE_BACKEND=mock
IMAGE_BATCH_SIZE_DEFAULT=4
IMAGE_WIDTH=1024
IMAGE_HEIGHT=1024
IMAGE_SEED_BASE=42

# Prompt strategy: llm (uses LLM extraction) or template (determinista)
PROMPT_STRATEGY=llm

# Storage (local | s3 | r2)
MEDIA_ROOT=./media
STORAGE_BACKEND=local
STORAGE_BASE_URL=http://localhost:8000/media

# ComfyUI
COMFY_BACKEND=local
COMFY_URL=http://host.docker.internal:8188

# ─── Base de datos ───────────────────────────────────────────────────────────
# COMPOSE_PROFILES controla qué servicios Docker arranca:
#   vacío (dev)        → solo qdrant + redis; la app usa SQLite (archivo local)
#   postgres (prod)    → además levanta el contenedor postgres
#
# Dev / local:
COMPOSE_PROFILES=
DATABASE_URL=sqlite:///./loremaster.db

# Producción (descomentar las dos líneas y comentar las de dev):
# COMPOSE_PROFILES=postgres
# DATABASE_URL=postgresql://loremaster:loremaster@localhost:5433/loremaster
# ─────────────────────────────────────────────────────────────────────────────