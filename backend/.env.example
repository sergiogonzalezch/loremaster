# OPENAI_BASE_URL=
# OPENAI_API_KEY=
# MODEL_NAME=
# # MODEL_NAME=

# LLM (Ollama local — NO OpenAI en dev)
OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.2:3b

# Vector DB
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=loremaster

# Cache
REDIS_URL=redis://redis:6379/0
CACHE_TTL=3600

# Storage (LocalStack dev)
STORAGE_BACKEND=localstack
S3_ENDPOINT_URL=http://localstack:4566
S3_BUCKET=loremaster-images
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

# Base de datos
DATABASE_URL=sqlite:///./loremaster.db

# ComfyUI (sem.7+)
COMFY_BACKEND=local
COMFY_URL=http://host.docker.internal:8188